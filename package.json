{
	"name": "bare-svelte",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"build:bare": "bare-build --out build/darwin-arm64 --host darwin-arm64 --runtime bare-native/runtime build/index.js",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"@sveltejs/adapter-node": "^5.5.4",
		"adapter-bare": "file:packages/adapter-bare",
		"b4a": "^1.8.0",
		"bare-buffer": "^3.6.0",
		"bare-build": "^0.5.3",
		"bare-crypto": "^1.13.4",
		"bare-encoding": "^1.0.3",
		"bare-fetch": "^2.8.2",
		"bare-fs": "^4.7.1",
		"bare-http1": "^4.5.6",
		"bare-native": "^0.1.2",
		"bare-path": "^3.0.0",
		"bare-process": "^4.4.1",
		"bare-querystring": "^1.1.0",
		"bare-stream": "^2.9.1",
		"bare-timers": "^3.2.1",
		"bare-url": "^2.4.2",
		"corestore": "^7.9.2",
		"esbuild": "^0.28.0",
		"graceful-goodbye": "^1.3.3",
		"paparam": "^1.10.1",
		"ready-resource": "^1.2.0"
	}
}
